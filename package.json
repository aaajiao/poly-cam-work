{
  "name": "poly-cam-work",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "bun run api/dev-server.ts",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "bun run test:vitest",
    "test:vitest": "vitest run",
    "test:vitest:unit": "vitest run --project unit",
    "test:vitest:browser": "vitest run --project browser",
    "test:watch": "vitest",
    "test:e2e": "playwright test e2e/smoke.test.ts",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "bun run test:vitest && bun run test:e2e",
    "cleanup:orphans": "bun run scripts/cleanup-orphan-assets.ts",
    "cleanup:orphans:dry": "bun run scripts/cleanup-orphan-assets.ts --dry-run"
  },
  "dependencies": {
    "@vercel/blob": "^2.0.0",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^9.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shadcn": "^3.8.5",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2",
    "three-mesh-bvh": "^0.9.9",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.3.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "eslint": "^10.0.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.56.1",
    "vite": "^6.0.5",
    "vitest": "^4.0.18",
    "vitest-browser-react": "^2.0.5"
  }
}
